<?xml version="1.0" encoding="utf-8"?>
<!--
    Kamera Konfigurátor overlay panel (M05)
    Teljes szélességű, alulról slide-up. Kezdetben GONE.
    Beillesztve: activity_mission_planner.xml gyökér FrameLayout-jába.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cameraPanelOverlay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="#F01a1a2e"
    android:elevation="10dp"
    android:clickable="true"
    android:focusable="true"
    android:visibility="gone">

    <!-- Fejléc -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:background="#221a1a2e">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷  Kamera"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <!-- AUTO / MANUÁLIS váltó -->
        <Button
            android:id="@+id/btnModeAuto"
            android:layout_width="80dp"
            android:layout_height="28dp"
            android:text="AUTO"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="0dp"
            android:backgroundTint="#FF6600"/>

        <Button
            android:id="@+id/btnModeManual"
            android:layout_width="100dp"
            android:layout_height="28dp"
            android:text="MANUÁLIS"
            android:textSize="11sp"
            android:textColor="#888888"
            android:padding="0dp"
            android:backgroundTint="#334466"/>

        <!-- Státusz szöveg -->
        <TextView
            android:id="@+id/tvCameraStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#88FFAA66"
            android:textSize="11sp"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnCameraPanelClose"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:padding="0dp"
            android:backgroundTint="#00000000"/>

    </LinearLayout>

    <!-- Vékony elválasztó -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334466"/>

    <!-- Fő tartalom: bal + jobb oszlop -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- ═══════════════════════════════════════════════
             BAL OSZLOP: Hisztogram + EV csúszka
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <!-- Hisztogram -->
            <com.dronefly.app.camera.HistogramView
                android:id="@+id/histogramView"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="#0D0D1A"/>

            <!-- EV csúszka sor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <Button
                    android:id="@+id/btnEvMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="◄"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"
                    android:backgroundTint="#334466"/>

                <SeekBar
                    android:id="@+id/seekbarEv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="60"
                    android:progress="30"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:progressTint="#FF8800"
                    android:thumbTint="#FF8800"/>

                <Button
                    android:id="@+id/btnEvPlus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="►"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"
                    android:backgroundTint="#334466"/>

            </LinearLayout>

            <!-- EV felirat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="alulexp."
                    android:textColor="#557799"
                    android:textSize="9sp"/>

                <TextView
                    android:id="@+id/tvEvValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EV ±0"
                    android:textColor="#FF8800"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="túlexp."
                    android:textColor="#557799"
                    android:textSize="9sp"
                    android:gravity="end"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Függőleges elválasztó -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#334466"
            android:layout_marginEnd="8dp"/>

        <!-- ═══════════════════════════════════════════════
             JOBB OSZLOP: Paraméterek
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cameraParamsGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:orientation="vertical">

            <!-- ISO sor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="ISO"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>

                <Button
                    android:id="@+id/btnIso100"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="100"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#FF6600"/>

                <Button
                    android:id="@+id/btnIso200"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="200"
                    android:textSize="11sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#334466"/>

                <Button
                    android:id="@+id/btnIso400"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="400"
                    android:textSize="11sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#334466"/>

                <Button
                    android:id="@+id/btnIso800"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="800"
                    android:textSize="11sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:backgroundTint="#334466"/>

            </LinearLayout>

            <!-- Rekesz sor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="Rekesz"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>

                <Button
                    android:id="@+id/btnApF56"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="f/5.6"
                    android:textSize="11sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#334466"/>

                <Button
                    android:id="@+id/btnApF8"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="f/8"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#FF6600"/>

                <Button
                    android:id="@+id/btnApF11"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="f/11"
                    android:textSize="11sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:backgroundTint="#334466"/>

            </LinearLayout>

            <!-- Zársebesség sor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="Zár"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/seekbarShutter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="7"
                    android:progress="3"
                    android:progressTint="#AADDFF"
                    android:thumbTint="#AADDFF"/>

                <TextView
                    android:id="@+id/tvShutterValue"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="1/800"
                    android:textColor="#AADDFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Fehéregyensúly sor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="WB"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/seekbarWb"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="30"
                    android:progress="16"
                    android:progressTint="#FFEE88"
                    android:thumbTint="#FFEE88"/>

                <TextView
                    android:id="@+id/tvWbValue"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="5600K"
                    android:textColor="#FFEE88"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Fókusz sor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="Fókusz"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"/>

                <Button
                    android:id="@+id/btnFocusAuto"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:text="AF → Rögzít"
                    android:textSize="10sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#334466"/>

                <Button
                    android:id="@+id/btnFocusInf"
                    android:layout_width="48dp"
                    android:layout_height="32dp"
                    android:text="∞"
                    android:textSize="14sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:backgroundTint="#334466"/>

            </LinearLayout>

            <!-- Profil + Alkalmaz sor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#334466"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Spinner
                    android:id="@+id/spinnerCameraProfile"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:backgroundTint="#AADDFF"
                    android:popupBackground="#1a1a2e"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btnCameraProfileSave"
                    android:layout_width="60dp"
                    android:layout_height="32dp"
                    android:text="Ment..."
                    android:textSize="10sp"
                    android:textColor="#CCCCCC"
                    android:padding="0dp"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#1a3a5a"/>

                <!-- AUTO módban: lock gomb; MANUÁLIS módban: alkalmaz gomb -->
                <Button
                    android:id="@+id/btnAutoLock"
                    android:layout_width="100dp"
                    android:layout_height="32dp"
                    android:text="🔒 Lock AUTO"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:backgroundTint="#885500"
                    android:visibility="visible"/>

                <Button
                    android:id="@+id/btnApplyCamera"
                    android:layout_width="90dp"
                    android:layout_height="32dp"
                    android:text="Alkalmaz ✓"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:padding="0dp"
                    android:backgroundTint="#006600"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
