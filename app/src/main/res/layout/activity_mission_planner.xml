<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- TÉRKÉP (bal oldal, 65%) + GPS gomb rárakva -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="65">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"/>

        <!-- Jobb felső sarok: GPS + térképváltó gombok -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:orientation="vertical"
            android:layout_margin="8dp"
            android:elevation="4dp">

            <Button
                android:id="@+id/btnMyLocation"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="GPS"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC1a1a2e"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnMapToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="SAT"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC1a1a2e"/>

        </LinearLayout>

    </FrameLayout>

    <!-- OLDALPANEL (jobb oldal, 35%) -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="35"
        android:background="#1a1a2e">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Drón kiválasztás -->
            <TextView
                android:text="Drón"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"/>
            <Spinner
                android:id="@+id/spinnerDrone"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="4dp"
                android:backgroundTint="#AADDFF"
                android:popupBackground="#1a1a2e"/>

            <!-- DJI kapcsolat státusz -->
            <TextView
                android:id="@+id/tvDroneStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="● Drón: nem csatlakoztatva"
                android:textColor="#FF4444"
                android:textSize="11sp"/>

            <!-- Cím -->
            <TextView
                android:text="Misszió beállítások"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <!-- GSD -->
            <TextView android:id="@+id/tvGsd"
                android:textColor="#FFAA00"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sbGsd"
                android:max="90"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- Sidelap -->
            <TextView android:id="@+id/tvSidelap"
                android:textColor="#AADDFF"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sbSidelap"
                android:max="40"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- Frontlap -->
            <TextView android:id="@+id/tvFrontlap"
                android:textColor="#AADDFF"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sbFrontlap"
                android:max="30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- Sebesség -->
            <TextView android:id="@+id/tvSpeed"
                android:textColor="#AADDFF"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sbSpeed"
                android:max="12"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <!-- Repülési irány -->
            <TextView android:id="@+id/tvAngle"
                android:textColor="#AADDFF"
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sbAngle"
                android:max="179"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Vezérlő gombok -->
            <Button android:id="@+id/btnDrawMode"
                android:text="Terület rajzolása"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#004499"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnClear"
                android:text="Törlés"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#660000"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnGenerate"
                android:text="Misszió generálása"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#006600"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnSetStart"
                android:text="Start/Home pont"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#005566"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnImportCsv"
                android:text="CSV importálása"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#555500"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnExport"
                android:text="Exportálás (CSV / KMZ)"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#334400"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnUpload"
                android:text="Feltöltés"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:textSize="13sp"
                android:backgroundTint="#884400"
                android:layout_marginBottom="6dp"/>

            <Button android:id="@+id/btnStart"
                android:text="START"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FF6600"
                android:enabled="false"
                android:layout_marginBottom="4dp"/>

            <!-- Misszió közbeni vezérlés -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button android:id="@+id/btnPauseMission"
                    android:text="⏸ Szünet"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:backgroundTint="#885500"
                    android:layout_marginEnd="3dp"
                    android:enabled="false"/>

                <Button android:id="@+id/btnStopMission"
                    android:text="⏹ Stop"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:backgroundTint="#880000"
                    android:layout_marginStart="3dp"
                    android:enabled="false"/>

            </LinearLayout>

            <!-- Statisztikák -->
            <TextView android:id="@+id/tvStats"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
