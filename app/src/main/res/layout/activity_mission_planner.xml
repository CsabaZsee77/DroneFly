<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TÉRKÉP (teljes háttér) -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"/>

        <!-- Bal felső sarok: GPS + térképváltó + CAM gombok -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:orientation="vertical"
            android:layout_margin="8dp"
            android:elevation="4dp">

            <Button
                android:id="@+id/btnMyLocation"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="GPS"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC1a1a2e"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnMapToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="SAT"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC1a1a2e"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnCamToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="CAM"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC1a1a2e"
                android:layout_marginBottom="8dp"/>

            <!-- Réteg gombok elválasztó -->
            <View
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:background="#CC334466"
                android:layout_marginBottom="8dp"/>

            <!-- Védett területek (Natura 2000 + NP) -->
            <Button
                android:id="@+id/btnLayerProtected"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="N2K"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC1a2e1a"
                android:layout_marginBottom="4dp"/>

            <!-- Légtér (OpenAIP) -->
            <Button
                android:id="@+id/btnLayerAirspace"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="LGT"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC2e1a1a"
                android:layout_marginBottom="2dp"/>

            <!-- LGT magassági szűrő: koppintásra vált ∞ ↔ 120m -->
            <Button
                android:id="@+id/btnAltFilter"
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:text="ALT:∞"
                android:textSize="9sp"
                android:textColor="#FFAA44"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#991a0a0a"
                android:layout_marginBottom="4dp"/>

            <!-- Területhasználati zónák (landuse) -->
            <Button
                android:id="@+id/btnLayerLandUse"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="ZÓN"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:padding="0dp"
                android:backgroundTint="#CC2e1a00"/>

        </LinearLayout>

        <!-- Bal alsó sarok: kamera feed ablak (bekapcsolható PiP) -->
        <FrameLayout
            android:id="@+id/cameraWindow"
            android:layout_width="256dp"
            android:layout_height="144dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:background="#CC000000"
            android:elevation="6dp"
            android:visibility="gone">

            <!-- Élő kamerakép -->
            <TextureView
                android:id="@+id/cameraTextureView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Fókusz jelző kör (tap-to-focus) -->
            <ImageView
                android:id="@+id/focusRing"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/focus_ring"
                android:visibility="invisible"
                android:elevation="8dp"/>

            <!-- Fejléc sáv: "LIVE" felirat + bezáró gomb -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:layout_gravity="top"
                android:background="#AA000000"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● LIVE"
                    android:textColor="#FF4444"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnCamClose"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="✕"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:padding="0dp"
                    android:backgroundTint="#00000000"/>

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- STÁTUSZSÁV – lebegő sziget a térkép tetején, az oldalsáv mellett ér véget -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="8dp"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="364dp"
        android:background="@drawable/status_bar_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="6dp">

        <!-- Drón kapcsolat -->
        <TextView
            android:id="@+id/sbDrone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DRON: --"
            android:textColor="#FF4444"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"/>

        <!-- Elválasztó -->
        <View android:layout_width="1dp" android:layout_height="20dp" android:background="#334466" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>

        <!-- RC kapcsolat + akku -->
        <TextView
            android:id="@+id/sbRc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RC: --"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/sbRcBatt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <!-- Elválasztó -->
        <View android:layout_width="1dp" android:layout_height="20dp" android:background="#334466" android:layout_marginEnd="6dp"/>

        <!-- GPS műholdak -->
        <TextView
            android:id="@+id/sbGps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAT: --"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <!-- Elválasztó -->
        <View android:layout_width="1dp" android:layout_height="20dp" android:background="#334466" android:layout_marginEnd="6dp"/>

        <!-- Drón akku -->
        <TextView
            android:id="@+id/sbDroneBatt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DRON AKKU: --"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <!-- Elválasztó -->
        <View android:layout_width="1dp" android:layout_height="20dp" android:background="#334466" android:layout_marginEnd="6dp"/>

        <!-- Tablet akku -->
        <TextView
            android:id="@+id/sbTabletBatt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAB: --"
            android:textColor="#888888"
            android:textSize="11sp"/>

        <!-- Elválasztó -->
        <View android:layout_width="1dp" android:layout_height="20dp" android:background="#334466" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>

        <!-- Geomágneses aktivitás (NOAA Kp-index) -->
        <TextView
            android:id="@+id/sbKp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAG: --"
            android:textColor="#888888"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- OLDALPANEL + TOGGLE GOMB együtt csúszik -->
    <LinearLayout
        android:id="@+id/sidePanelContainer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:elevation="8dp">

        <!-- Toggle gomb – a panel bal szélén, alul (véletlen bezárás ellen) -->
        <Button
            android:id="@+id/btnTogglePanel"
            android:layout_width="36dp"
            android:layout_height="72dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="24dp"
            android:text="»"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="0dp"
            android:backgroundTint="#CC1a1a2e"
            android:elevation="2dp"/>

        <!-- Panel tartalma – a toggle gombtól jobbra -->
        <ScrollView
            android:id="@+id/sidePanel"
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:background="#EE1a1a2e">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Drón kiválasztás -->
                <TextView
                    android:text="Drón"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"/>
                <Spinner
                    android:id="@+id/spinnerDrone"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="4dp"
                    android:backgroundTint="#AADDFF"
                    android:popupBackground="#1a1a2e"/>

                <!-- DJI kapcsolat státusz -->
                <TextView
                    android:id="@+id/tvDroneStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Drón: nincs csatlakoztatva"
                    android:textColor="#FF4444"
                    android:textSize="11sp"/>

                <!-- Cím -->
                <TextView
                    android:text="Misszió beállitások"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <!-- GSD -->
                <TextView android:id="@+id/tvGsd"
                    android:textColor="#FFAA00"
                    android:textSize="12sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <SeekBar android:id="@+id/sbGsd"
                    android:max="90"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Sidelap -->
                <TextView android:id="@+id/tvSidelap"
                    android:textColor="#AADDFF"
                    android:textSize="12sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <SeekBar android:id="@+id/sbSidelap"
                    android:max="40"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Frontlap -->
                <TextView android:id="@+id/tvFrontlap"
                    android:textColor="#AADDFF"
                    android:textSize="12sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <SeekBar android:id="@+id/sbFrontlap"
                    android:max="30"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Sebesség -->
                <TextView android:id="@+id/tvSpeed"
                    android:textColor="#AADDFF"
                    android:textSize="12sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <SeekBar android:id="@+id/sbSpeed"
                    android:max="12"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Repülési irány -->
                <TextView android:id="@+id/tvAngle"
                    android:textColor="#AADDFF"
                    android:textSize="12sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <SeekBar android:id="@+id/sbAngle"
                    android:max="179"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Offset (túlrepülési határ) -->
                <TextView android:id="@+id/tvOffset"
                    android:textColor="#AADDFF"
                    android:textSize="12sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <SeekBar android:id="@+id/sbOffset"
                    android:max="30"
                    android:progress="0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Domborzatkövetés -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#334466"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:text="Domborzatkovetes:"
                        android:textColor="#AADDFF"
                        android:textSize="12sp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <Switch
                        android:id="@+id/switchTerrain"
                        android:textColor="#AADDFF"
                        android:textSize="12sp"
                        android:checked="false"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTerrainInfo"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:text="Magassag korrekció DEM (SRTM) domborzati modell alapjan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <!-- Kamera beállítások (összecsukható) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#334466"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:id="@+id/cameraHeader"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">
                    <TextView
                        android:text="Kamera beallitasok"
                        android:textColor="#AADDFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <TextView
                        android:id="@+id/tvCameraExpand"
                        android:text="▼"
                        android:textColor="#AADDFF"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cameraSettingsBody"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:text="Mod:"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"/>
                        <Switch
                            android:id="@+id/switchCameraAuto"
                            android:text="Auto"
                            android:textColor="#AADDFF"
                            android:textSize="12sp"
                            android:checked="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <TextView
                        android:text="Fajlformatum:"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <Spinner
                        android:id="@+id/spinnerFileFormat"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:id="@+id/cameraManualControls"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="Foto mod:"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <Spinner
                            android:id="@+id/spinnerPhotoMode"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:text="ISO:"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <Spinner
                            android:id="@+id/spinnerIso"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:text="Zarido:"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <Spinner
                            android:id="@+id/spinnerShutter"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:text="Feheregyensuly:"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <Spinner
                            android:id="@+id/spinnerWhiteBalance"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginBottom="6dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#334466"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"/>

                <!-- Projekt mentés / betöltés -->
                <Button android:id="@+id/btnNewPlan"
                    android:text="Uj terv"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#4a235a"
                    android:layout_marginBottom="6dp"/>

                <TextView android:id="@+id/tvCurrentPlanName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mentetlen terv"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <Button android:id="@+id/btnSaveProject"
                        android:text="Mentes"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:backgroundTint="#1a5276"
                        android:layout_marginEnd="3dp"/>

                    <Button android:id="@+id/btnSaveAsProject"
                        android:text="Mentes masként"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:textSize="11sp"
                        android:backgroundTint="#154360"/>
                </LinearLayout>

                <Button android:id="@+id/btnLoadProject"
                    android:text="Terv betoltese"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#154360"
                    android:layout_marginBottom="6dp"/>

                <!-- Vezérlő gombok -->
                <Button android:id="@+id/btnUndoPoint"
                    android:text="Utolso pont torles"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#334466"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnObstacle"
                    android:text="+ Akadaly jelolese"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#662200"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnClearObstacles"
                    android:text="Akadalyok torlese"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="12sp"
                    android:backgroundTint="#441100"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnClear"
                    android:text="Osszes torles"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#660000"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnGenerate"
                    android:text="Ujragenerales (beallitasokkal)"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="12sp"
                    android:backgroundTint="#006600"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnSetStart"
                    android:text="Start/Home pont"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#005566"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnImportCsv"
                    android:text="CSV importalasa"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#555500"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnExport"
                    android:text="Exportalas (CSV / KMZ)"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#334400"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnSimulate"
                    android:text="Szimulacio"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#005533"
                    android:enabled="false"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnUpload"
                    android:text="Feltoltes"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:textSize="13sp"
                    android:backgroundTint="#884400"
                    android:layout_marginBottom="6dp"/>

                <Button android:id="@+id/btnStart"
                    android:text="START"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FF6600"
                    android:enabled="false"
                    android:layout_marginBottom="4dp"/>

                <!-- Misszió haladás -->
                <TextView
                    android:id="@+id/tvMissionProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFAA00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="2dp"/>

                <ProgressBar
                    android:id="@+id/pbMissionProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#FF6600"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- Misszió közbeni vezérlés -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <Button android:id="@+id/btnPauseMission"
                        android:text="Szunet"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:backgroundTint="#885500"
                        android:layout_marginEnd="3dp"
                        android:enabled="false"/>

                    <Button android:id="@+id/btnStopMission"
                        android:text="Stop"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:backgroundTint="#880000"
                        android:layout_marginStart="3dp"
                        android:enabled="false"/>

                </LinearLayout>

                <!-- Statisztikák -->
                <TextView android:id="@+id/tvStats"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</FrameLayout>
